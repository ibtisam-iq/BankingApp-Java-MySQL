# ============================================================
# .env.example — Template for environment configuration
# Copy this file to .env and fill in real values
# The actual .env file is git-ignored and must NEVER be committed
# ============================================================

# MySQL Credentials
MYSQL_ROOT_PASSWORD=your_root_password_here
MYSQL_DATABASE=bankappdb
MYSQL_USER=your_db_user
MYSQL_PASSWORD=your_db_password

# Spring Boot App Variables
SPRING_APPLICATION_NAME=BankApp
SPRING_DATASOURCE_URL=jdbc:mysql://db:3306/bankappdb?useSSL=false&serverTimezone=UTC&allowPublicKeyRetrieval=true
SPRING_DATASOURCE_USERNAME=your_db_user
SPRING_DATASOURCE_PASSWORD=your_db_password
SPRING_DATASOURCE_DRIVER_CLASS_NAME=com.mysql.cj.jdbc.Driver

# JPA & Hibernate configuration
# MySQLDialect replaces deprecated MySQL8Dialect (Hibernate 6 / Spring Boot 3.x)
SPRING_JPA_HIBERNATE_DDL_AUTO=update
SPRING_JPA_PROPERTIES_HIBERNATE_DIALECT=org.hibernate.dialect.MySQLDialect
SPRING_JPA_SHOW_SQL=false

SERVER_PORT=8000
