# ============================================================
# .env.example — Template for environment configuration
# Copy this file to .env and fill in real values before running the application.
# ============================================================

# MySQL Credentials
MYSQL_ROOT_PASSWORD=your_root_password_here
MYSQL_DATABASE=IbtisamIQbankappdb
MYSQL_USER=your_db_user
MYSQL_PASSWORD=your_db_password

# Spring Boot App Variables
SPRING_APPLICATION_NAME=IbtisamIQBankApp
SPRING_DATASOURCE_URL="jdbc:mysql://localhost:3306/IbtisamIQbankappdb?useSSL=false&serverTimezone=UTC&allowPublicKeyRetrieval=true"
SPRING_DATASOURCE_USERNAME=your_db_user         # MYSQL_USER
SPRING_DATASOURCE_PASSWORD=your_db_password     # MYSQL_PASSWORD
SPRING_DATASOURCE_DRIVER_CLASS_NAME=com.mysql.cj.jdbc.Driver

# JPA & Hibernate configuration
SPRING_JPA_HIBERNATE_DDL_AUTO=update
SPRING_JPA_PROPERTIES_HIBERNATE_DIALECT=org.hibernate.dialect.MySQLDialect
SPRING_JPA_SHOW_SQL=true

SERVER_PORT=8000
